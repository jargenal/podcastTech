{
  "host": "127.0.0.1",
  "port": 8040,
  "app_title": "PodcastTech Offline TTS",
  "default_language": "es",
  "default_variant": "es_latam",
  "default_voice": "voices/default_es_mx.wav",
  "default_speed": 1.0,
  "default_english_speed": 1.0,
  "default_segment_length": 220,
  "default_temperature": 0.65,
  "default_english_temperature": 0.45,
  "default_pause_ms": 700,
  "normalize_audio": true,
  "output_format": "wav",
  "output_dir": "output",
  "input_dir": "input",
  "voices_dir": "voices",
  "temp_dir": "temp",
  "history_file": "output/history.json",
  "playlists_file": "output/playlists.json",
  "variants": {
    "es_latam": {
      "label": "Español Latinoamericano",
      "tts_language": "es",
      "default_voice": "voices/default_es_mx.wav",
      "fallback_variant": "es_neutro"
    },
    "es_neutro": {
      "label": "Español Neutro",
      "tts_language": "es",
      "default_voice": "voices/default_es_mx.wav",
      "fallback_variant": "es_latam"
    },
    "es_es": {
      "label": "Español España",
      "tts_language": "es",
      "default_voice": "voices/default_es_mx.wav",
      "fallback_variant": "es_neutro"
    }
  },
  "tts": {
    "engine": "xtts_v2",
    "xtts_model_name": "tts_models/multilingual/multi-dataset/xtts_v2",
    "device_preference": "cpu"
  },
  "speech": {
    "enabled": true,
    "spell_acronyms": true,
    "technical_verbalization_mode": "expanded",
    "alphanumeric_acronym_mode": "lexicon",
    "mixed_case_id_pronunciation": "compact",
    "pronunciation_mode": "conservative",
    "technical_adaptation_aggressiveness": "conservative",
    "preserve_english_spans": true,
    "adapt_english_spans_with_lexicon": false,
    "spanglishify_english_spans": false,
    "adapt_plain_english_terms_with_lexicon": false,
    "restore_spanish_accents": true,
    "pronunciation_lexicon_overrides_file": "app/config/lexicons/pronunciation_overrides.json",
    "accent_lexicon_overrides_file": "app/config/lexicons/accent_overrides.json"
  },
  "eco_mode": {
    "enabled": true,
    "max_torch_threads": 4,
    "max_interop_threads": 1,
    "inter_segment_cooldown_ms": 250
  },
  "audio_tuning": {
    "reading_mode": "technical_paragraph",
    "sentence_pause_ms": 220,
    "segment_fade_ms": 28,
    "segment_fade_in_ms": 6,
    "segment_fade_out_ms": 0,
    "terminal_segment_fade_out_ms": 0,
    "terminal_segment_tail_silence_ms": 60,
    "short_segment_fade_ms": 8,
    "crossfade_ms": 18,
    "same_language_crossfade_ms": 12,
    "bilingual_crossfade_ms": 0,
    "same_language_crossfade_for_sensitive_segments_ms": 0,
    "disable_fades_for_sensitive_segments": true,
    "min_chars_for_crossfade": 95,
    "segment_join_strategy": "conservative",
    "bilingual_transition_pause_ms": 120,
    "technical_bilingual_transition_pause_ms": 70,
    "min_segment_chars": 70,
    "protected_token_context_words_before": 2,
    "protected_token_context_words_after": 3,
    "avoid_segment_break_after_technical_token": true,
    "avoid_segment_break_before_technical_token": true,
    "protected_zone_max_overflow_chars": 80,
    "sensitive_segment_detection": true,
    "preserve_terminal_punctuation": true,
    "strip_terminal_periods": false
  }
}
